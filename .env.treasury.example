# Treasury host only — copy to .env on the machine running treasury Sage + pnpm dev:treasury
# Do NOT put this file on the game server or player devices.
# See docs/TREASURY.md

# Same DAT CAT asset id as the game host
DAT_GOVERNANCE_TOKEN_ASSET_ID=

# Treasury payout service (game API calls this over private network)
TREASURY_PORT=4200
TREASURY_HOST=0.0.0.0
TREASURY_OFFER_MODE=rpc
TREASURY_PAYOUT_FEE_MOJOS=0

# Sage wallet RPC — always localhost on this machine
TREASURY_WALLET_BACKEND=sage
TREASURY_WALLET_RPC_URL=https://127.0.0.1:9257
# Fingerprint from Sage Settings or: sage rpc get_keys '{}'
TREASURY_SAGE_FINGERPRINT=
# Auto-detected on Linux: ~/.local/share/sage/ssl/wallet.{crt,key}
# TREASURY_WALLET_CERT_PATH=~/.local/share/sage/ssl/wallet.crt
# TREASURY_WALLET_KEY_PATH=~/.local/share/sage/ssl/wallet.key
TREASURY_WALLET_INSECURE=false
