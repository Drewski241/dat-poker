# API
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated browser origins allowed to call the API (default * = reflect any Origin)
# Example: https://poker.example.com,http://localhost:5173
API_CORS_ORIGINS=*

# Web dev server (pnpm dev:web)
WEB_HOST=0.0.0.0
WEB_PORT=5173
# Public API URL baked into production web build (leave empty for same-origin / dev proxy)
VITE_API_URL=

# Realtime gateway
GATEWAY_PORT=4100
GATEWAY_HOST=0.0.0.0

# DAT Governance Token (Chia CAT) — required for buy-ins / cash games
# Mainnet asset_id from your wallet or block explorer (64 hex chars)
DAT_GOVERNANCE_TOKEN_ASSET_ID=
DAT_GOVERNANCE_TOKEN_TICKER=DAT
DAT_ALLOW_DEV_BUYIN=false
# player = player wallet funds buy-in (virtual ledger). treasury = operator treasury supplies chips.
DAT_BUYIN_FUNDING=player
# Treasury-funded buy-in daily cap (10000 DAT = 10000000 mojos, rolling 24h window)
DAT_TREASURY_DAILY_BUYIN_LIMIT_MOJOS=10000000
# global = shared pool across all players; player = per wallet address
DAT_TREASURY_DAILY_BUYIN_SCOPE=global
# Minimum buy-in in CAT mojos (1 DAT = 1000 mojos). 1000000 = 1000 DAT.
# Do NOT use XCH-scale values (e.g. 2000000000000).
DAT_MIN_BUY_IN_MOJOS=1000000

# Withdraw / cash-out (virtual buy-in pays net winnings by default)
# net = pay stack minus original buy-in (e.g. +50 DAT after 1000 buy-in → 1050 stack)
# full = pay entire table stack on-chain (when buy-in is escrowed on-chain)
DAT_WITHDRAW_PAYOUT_MODE=net
# Withdraw — on game/API host, point to treasury machine (see docs/TREASURY.md)
# Dev (all on one box): http://localhost:4200/payout
# Production: http://TREASURY_HOST_PRIVATE_IP:4200/payout
DAT_TREASURY_PAYOUT_URL=http://localhost:4200/payout
DAT_WITHDRAW_FEE_MOJOS=0

# --- Treasury host only (same machine as treasury Sage; not on game server) ---
TREASURY_PORT=4200
TREASURY_HOST=0.0.0.0
# mock = dev only. rpc = Sage make_offer (requires Sage RPC running).
TREASURY_OFFER_MODE=rpc
TREASURY_WALLET_BACKEND=sage
TREASURY_WALLET_RPC_URL=https://127.0.0.1:9257
# Treasury Sage fingerprint (Settings → copy from Sage, or sage rpc get_keys)
TREASURY_SAGE_FINGERPRINT=
TREASURY_PAYOUT_FEE_MOJOS=0
# Auto-detected on Linux: ~/.local/share/sage/ssl/wallet.{crt,key}
# TREASURY_WALLET_CERT_PATH=~/.local/share/sage/ssl/wallet.crt
# TREASURY_WALLET_KEY_PATH=~/.local/share/sage/ssl/wallet.key
TREASURY_WALLET_INSECURE=false

# Chia / chia-gaming integration
CHIA_NETWORK=mainnet
CHIA_CHAIN_ID=chia:mainnet
CHIA_GAMING_LOBBY_URL=http://localhost:3001
CHIA_GAMING_GAME_URL=http://localhost:3000
COINSET_URL=https://coinset.org
WALLETCONNECT_PROJECT_ID=

# Postgres (future)
DATABASE_URL=postgres://dat_poker:dat_poker@localhost:5432/dat_poker

# Redis (future)
REDIS_URL=redis://localhost:6379
